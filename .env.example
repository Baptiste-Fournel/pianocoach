# Copy to .env and fill in. .env is gitignored and never committed.

# Gemini API key (free tier) — https://aistudio.google.com/app/apikey
# Required only for the in-app chat coach and AI video feedback.
GEMINI_API_KEY=

# Gemini model used for chat + multimodal video analysis.
GEMINI_MODEL=gemini-2.5-flash

# Privacy: when true, videos are NEVER sent to Gemini.
# Only local librosa metrics are computed. Default false.
VIDEO_LOCAL_ONLY=false

# Where local data lives (SQLite DB + videos). Relative to repo root.
DATA_DIR=./data
